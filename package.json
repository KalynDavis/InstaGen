{
  "name": "instagen",
  "version": "0.1.0",
  "description": "Generate Instagram story and post JPGs from HTML canvas.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "demo": "npm run build && vite demo --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "instagram",
    "canvas",
    "jpg",
    "story",
    "post",
    "social-media"
  ],
  "author": "KalynDavis",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.13"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "any-promise": "^1.3.0",
    "bundle-require": "^5.1.0",
    "cac": "^6.7.14",
    "chokidar": "^4.0.3",
    "commander": "^4.1.1",
    "confbox": "^0.1.8",
    "consola": "^3.4.2",
    "debug": "^4.4.3",
    "detect-libc": "^2.1.2",
    "esbuild": "^0.27.7",
    "fdir": "^6.5.0",
    "fix-dts-default-cjs-exports": "^1.0.1",
    "fsevents": "^2.3.3",
    "joycon": "^3.1.1",
    "lightningcss": "^1.32.0",
    "lightningcss-darwin-arm64": "^1.32.0",
    "lilconfig": "^3.1.3",
    "lines-and-columns": "^1.2.4",
    "load-tsconfig": "^0.2.5",
    "magic-string": "^0.30.21",
    "mlly": "^1.8.2",
    "ms": "^2.1.3",
    "mz": "^2.7.0",
    "nanoid": "^3.3.12",
    "object-assign": "^4.1.1",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "pirates": "^4.0.7",
    "pkg-types": "^1.3.1",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "readdirp": "^4.1.2",
    "resolve-from": "^5.0.0",
    "rolldown": "^1.0.1",
    "rollup": "^4.60.4",
    "source-map": "^0.7.6",
    "source-map-js": "^1.2.1",
    "sucrase": "^3.35.1",
    "thenify": "^3.3.1",
    "thenify-all": "^1.6.0",
    "tinyexec": "^0.3.2",
    "tinyglobby": "^0.2.16",
    "tree-kill": "^1.2.2",
    "ts-interface-checker": "^0.1.13",
    "ufo": "^1.6.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KalynDavis/InstaGen.git"
  },
  "bugs": {
    "url": "https://github.com/KalynDavis/InstaGen/issues"
  },
  "homepage": "https://github.com/KalynDavis/InstaGen#readme"
}
